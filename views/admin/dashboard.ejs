<%
function escHtml(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}
const bodyHtml = `
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-sidebar-title">Admin Panel</div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-link active">📊 Dashboard</a>
      <a href="/admin/requests" class="admin-nav-link">📬 Requests</a>
      <a href="/admin/servers" class="admin-nav-link">🌐 Servers</a>
      <a href="/admin/logs" class="admin-nav-link">📋 Logs</a>
      <a href="/admin/guidelines" class="admin-nav-link">📜 Guidelines</a>
      <a href="/admin/admins" class="admin-nav-link">🛡️ Admins</a>
      <a href="/admin/blacklist" class="admin-nav-link">🚫 Blacklist</a>
      <a href="/admin/analytics" class="admin-nav-link">📈 Analytics</a>
    </nav>
  </aside>

  <div class="admin-main">
    <div class="admin-page-header">
      <h1>Dashboard</h1>
      <p>Welcome back, ${escHtml(user.username)}</p>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">📬</div>
        <div class="stat-value">${pendingCount}</div>
        <div class="stat-label">Pending Requests</div>
        ${pendingCount > 0 ? '<a href="/admin/requests" class="stat-action">Review now →</a>' : ''}
      </div>
      <div class="stat-card">
        <div class="stat-icon">🌐</div>
        <div class="stat-value">${serverCount}</div>
        <div class="stat-label">Live Servers</div>
        <a href="/admin/servers" class="stat-action">Manage →</a>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🛡️</div>
        <div class="stat-value">${adminCount}</div>
        <div class="stat-label">Admins</div>
        <a href="/admin/admins" class="stat-action">Manage →</a>
      </div>
    </div>

    <div class="admin-section">
      <h2 class="admin-section-title">Recent Submissions</h2>
      ${recentRequests.length === 0 ? '<p class="empty-text">No submissions yet.</p>' : `
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Server</th>
                <th>Submitted by</th>
                <th>Date</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              ${recentRequests.map(r => `
                <tr>
                  <td><strong>${escHtml(r.name)}</strong><br><small class="muted">${escHtml(r.ip)}</small></td>
                  <td>${escHtml(r.submitted_by_username)}</td>
                  <td>${new Date(r.created_at).toLocaleDateString()}</td>
                  <td><span class="status-badge status-${escHtml(r.status)}">${escHtml(r.status)}</span></td>
                  <td><a href="/admin/requests?status=${encodeURIComponent(r.status)}" class="btn btn-xs btn-ghost">View</a></td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `}
    </div>
  </div>
</div>
`;
%>
<%- include('../layout', { body: bodyHtml, title: title, user: user, isAdmin: isAdmin }) %>
